# ── Database ──────────────────────────────────────────────────────────────────
# Async URL used by FastAPI routes
DATABASE_URL=postgresql+asyncpg://edi:edipass@postgres:5432/edi_middleware_update

# Sync URL used by Alembic migrations and RQ workers
DATABASE_SYNC_URL=postgresql+psycopg2://edi:edipass@postgres:5432/edi_middleware_update
POSTGRES_PASSWORD=edipass

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-hex-string
ENVIRONMENT=local       # local | staging | production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Sentry (error tracking) ───────────────────────────────────────────────────
SENTRY_DSN=

# ── SAP Business One Service Layer ───────────────────────────────────────────
# Default port: 50000 (HTTP dev), 50001 (HTTPS prod)
B1_SERVICE_LAYER_URL=https://your-b1-server:50001/b1s/v1
B1_COMPANY_DB=SBO_LETSTRY
B1_USERNAME=EDI_BOT
B1_PASSWORD=
B1_SESSION_POOL_SIZE=2
B1_VERIFY_SSL=true      # set false ONLY for dev with self-signed certs

# ── Gmail API ─────────────────────────────────────────────────────────────────
# Path to OAuth2 credentials.json downloaded from Google Cloud Console
GMAIL_CREDENTIALS_PATH=./credentials/gmail_credentials.json
# Path to token.json generated by scripts/auth_gmail.py
GMAIL_TOKEN_PATH=./credentials/gmail_token.json

# ── Seller entity ─────────────────────────────────────────────────────────────
SELLER_GSTIN=07AABCL1234C1ZX
SELLER_NAME=Let's Try Foods Private Limited
SELLER_B1_COMPANY_DB=SBO_LETSTRY

# ── Blinkit ───────────────────────────────────────────────────────────────────
BLINKIT_API_KEY=
BLINKIT_VENDOR_ID=18309
# Pre-prod: https://dev.partnersbiz.com  |  Prod: https://api.partnersbiz.com
BLINKIT_BASE_URL=https://dev.partnersbiz.com
BLINKIT_PATH_ASN=webhook/public/v1/asn
BLINKIT_PATH_PO_ACK=webhook/public/v1/po/acknowledgement

# ── Zepto ─────────────────────────────────────────────────────────────────────
ZEPTO_CLIENT_ID=
ZEPTO_CLIENT_SECRET=
# QA: https://silkroute.zeptonow.dev  |  Prod: https://silkroute.zepto.co.in
# Leave blank to auto-select by ENVIRONMENT
ZEPTO_BASE_URL=

# ── Swiggy (future) ───────────────────────────────────────────────────────────
SWIGGY_API_KEY=

# ── LLM fallback parser (Anthropic) ──────────────────────────────────────────
ANTHROPIC_API_KEY=
LLM_FALLBACK_MODEL=claude-sonnet-4-5

# ── Render.com (proxy for local dev, so Mac can reach Blinkit/Zepto) ─────────
# Only needed when ENVIRONMENT=local
RENDER_URL=https://po-integration-backend.onrender.com

# ── Attachment storage ────────────────────────────────────────────────────────
ATTACHMENT_BASE_PATH=./data/attachments
